# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Operator config points at a private dataset — never commit it. The repo ships a generic
# `docusearch.example.yaml`; the real config is passed with `--config` and stays untracked.
/docusearch.yaml

# Generated output — ALL generated output lands under tmp/. Transient, never tracked.
tmp/
staging/
catalog.db
*.db
*.db-wal
*.db-shm
*.hnsw

# OS noise
.DS_Store
Thumbs.db

# Deployment-specific profiles + verifiers. A customer's instrument rules are not part of the
# generic product, so profiles/ is ignored by DEFAULT except the seam (__init__.py). To ship a
# specific profile, opt it in with a `!` line below.
/src/docusearch/profiles/*
!/src/docusearch/profiles/__init__.py
# Domain skills that pair with a profile are deployment-specific too.
/.claude/skills/igxl/
